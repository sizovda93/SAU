# ===========================================
# IronChain SAU - Environment Variables
# Скопируйте этот файл в .env и заполните значения
# ===========================================

# --- PostgreSQL ---
DATABASE_HOST=your-server-ip
DATABASE_PORT=5432
DATABASE_NAME=ironchain_sau
DATABASE_USER=sau_app
DATABASE_PASSWORD=your-password
DATABASE_URL=postgresql://sau_app:your-password@your-server-ip:5432/ironchain_sau

# --- Backend API ---
API_PORT=3001
API_HOST=localhost
VITE_API_URL=http://localhost:3001/api

# --- Загрузка файлов ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
